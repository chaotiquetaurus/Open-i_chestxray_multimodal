# ============================================================
# Git LFS — fichiers lourds (data, modèles, images médicales)

# Imagerie médicale
*.dcm filter=lfs diff=lfs merge=lfs -text
*.nii filter=lfs diff=lfs merge=lfs -text
*.nii.gz filter=lfs diff=lfs merge=lfs -text
*.mha filter=lfs diff=lfs merge=lfs -text
*.mhd filter=lfs diff=lfs merge=lfs -text
# Modèles & checkpoints
*.pth filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.hdf5 filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.joblib filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
# Archives volumineuses
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.tgz filter=lfs diff=lfs merge=lfs -text
*.7z filter=lfs diff=lfs merge=lfs -text
# Données tabulaires volumineuses (à activer si besoin)
# *.parquet filter=lfs diff=lfs merge=lfs -text
# *.feather filter=lfs diff=lfs merge=lfs -text
# Normalisation EOL
* text=auto eol=lf
*.bat text eol=crlf
*.sh text eol=lf
data/**/*.png filter=lfs diff=lfs merge=lfs -text
